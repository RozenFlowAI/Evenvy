      },
      "categories": [
        { "id": "wedding", "label": "Weddings", "image": "https://images.pexels.com/photos/12919431/pexels-photo-12919431.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940" },
        { "id": "corporate", "label": "Corporate", "image": "https://images.unsplash.com/photo-1771911646904-61f0fc9033e2?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA3MDB8MHwxfHNlYXJjaHwyfHxjb3Jwb3JhdGUlMjBldmVudCUyMGhhbGwlMjBtb2Rlcm58ZW58MHx8fHwxNzc0MjYxMTg2fDA&ixlib=rb-4.1.0&q=85" },
        { "id": "party", "label": "Parties", "image": "https://images.unsplash.com/photo-1650727280099-13c5c01bc2c7?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAzNDR8MHwxfHNlYXJjaHw0fHxwYXJ0eSUyMHZlbnVlJTIwcm9vZnRvcCUyMG5pZ2h0fGVufDB8fHx8MTc3NDI2MTE4N3ww&ixlib=rb-4.1.0&q=85" }
      ]
