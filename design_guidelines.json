{
  "design_system": {
    "identity": {
      "name": "Lumina",
      "tagline": "Curated Spaces for Unforgettable Nights",
      "tone": "Elegant, Exclusive, Nocturnal, Trustworthy",
      "description": "A luxury event venue booking app that feels like a high-end lifestyle magazine. Dark, mysterious, and premium."
    },
    "typography": {
      "font_family": {
        "headings": "Playfair Display, serif",
        "body": "Lato, sans-serif",
        "notes": "Use @expo-google-fonts/playfair-display for Headings and @expo-google-fonts/lato for Body. If custom fonts fail, fallback to System Serif (iOS: Times New Roman, Android: serif) and System Sans (iOS: San Francisco, Android: Roboto)."
      },
      "scale": {
        "display": { "size": 32, "line_height": 40, "weight": "700", "tracking": -0.5 },
        "h1": { "size": 28, "line_height": 34, "weight": "700", "tracking": -0.5 },
        "h2": { "size": 24, "line_height": 30, "weight": "600", "tracking": 0 },
        "h3": { "size": 20, "line_height": 26, "weight": "600", "tracking": 0.1 },
        "body_lg": { "size": 16, "line_height": 24, "weight": "400", "tracking": 0.2 },
        "body_sm": { "size": 14, "line_height": 20, "weight": "400", "tracking": 0.2 },
        "caption": { "size": 12, "line_height": 16, "weight": "500", "tracking": 0.5, "transform": "uppercase" }
      }
    },
    "colors": {
      "theme": "dark",
      "palette": {
        "background": {
          "default": "#050505",
          "surface": "#121212",
          "surface_highlight": "#1E1E1E",
          "overlay": "rgba(0,0,0,0.7)"
        },
        "text": {
          "primary": "#FFFFFF",
          "secondary": "#A1A1AA",
          "tertiary": "#52525B",
          "inverse": "#000000"
        },
        "primary": {
          "main": "#D4AF37",
          "light": "#F3E5AB",
          "dark": "#997B1E",
          "contrast": "#000000"
        },
        "status": {
          "success": "#10B981",
          "error": "#EF4444",
          "warning": "#F59E0B",
          "info": "#3B82F6"
        },
        "border": {
          "default": "#27272A",
          "active": "#D4AF37"
        }
      }
    },
    "spacing": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24,
      "xl": 32,
      "xxl": 48,
      "section_gap": 40
    },
    "layout": {
      "border_radius": {
        "sm": 4,
        "md": 8,
        "lg": 16,
        "xl": 24,
        "full": 9999
      },
      "touch_target": 48,
      "safe_area_padding": true
    },
    "shadows": {
      "card": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 4 },
        "shadowOpacity": 0.3,
        "shadowRadius": 4.65,
        "elevation": 8
      },
      "glow": {
        "shadowColor": "#D4AF37",
        "shadowOffset": { "width": 0, "height": 0 },
        "shadowOpacity": 0.2,
        "shadowRadius": 10,
        "elevation": 5
      }
    }
  },
  "components": {
    "buttons": {
      "primary": {
        "backgroundColor": "#D4AF37",
        "paddingVertical": 16,
        "borderRadius": 9999,
        "alignItems": "center",
        "textStyle": { "color": "#000000", "fontWeight": "700", "fontSize": 16, "fontFamily": "System" }
      },
      "secondary": {
        "backgroundColor": "transparent",
        "borderWidth": 1,
        "borderColor": "#D4AF37",
        "paddingVertical": 16,
        "borderRadius": 9999,
        "alignItems": "center",
        "textStyle": { "color": "#D4AF37", "fontWeight": "600", "fontSize": 16 }
      },
      "ghost": {
        "backgroundColor": "transparent",
        "paddingVertical": 12,
        "alignItems": "center",
        "textStyle": { "color": "#FFFFFF", "fontSize": 14, "textDecorationLine": "underline" }
      }
    },
    "inputs": {
      "default": {
        "backgroundColor": "#1E1E1E",
        "borderRadius": 12,
        "padding": 16,
        "color": "#FFFFFF",
        "fontSize": 16,
        "borderWidth": 1,
        "borderColor": "#27272A"
      },
      "focused": {
        "borderColor": "#D4AF37"
      }
    },
    "cards": {
      "venue": {
        "backgroundColor": "#121212",
        "borderRadius": 16,
        "overflow": "hidden",
        "marginBottom": 24,
        "elevation": 5
      }
    }
  },
