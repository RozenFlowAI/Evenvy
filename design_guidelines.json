    "icons": {
      "library": "@expo/vector-icons",
      "sets": ["Ionicons", "MaterialCommunityIcons", "Feather"],
      "style": "Stroke (Outline) for inactive, Filled for active"
    }
  },
  "react_native_rules": {
    "styling": {
      "engine": "StyleSheet.create",
      "units": "dp (density-independent pixels)",
      "flexbox": "Use Flexbox for everything. default flexDirection is column in RN.",
      "safe_area": "ALWAYS use SafeAreaView from react-native-safe-area-context for root containers."
    },
    "navigation": {
      "library": "expo-router",
      "structure": "File-based routing (/app directory)",
      "tabs": "Use Tabs from expo-router for main navigation."
    },
    "performance": {
      "lists": "Use FlatList for lists of data. Do NOT use ScrollView for large lists.",
      "images": "Use Image from expo-image if available, otherwise standard Image. Always set dimensions."
    }
  },
  "guidelines_for_agent": {
    "general": "You are building a React Native Expo app, NOT a React Web app. Do not use HTML tags like <div>, <p>, <span>. Use <View>, <Text>, <TouchableOpacity>. Do not use 'className', use 'style'.",
    "theme_implementation": "Hardcode the Dark Theme colors for now to ensure consistency. Do not rely on system theme detection unless specified.",
    "layout_strategy": "Use a 'Bento' grid style for the Discovery/Home page. Mix large vertical cards with smaller square cards.",
    "booking_flow": "Keep it contact-based. The 'Book' button should open a modal/screen to fill out a request form (Date, Guest Count, Message), which then sends a request (mocked API).",
    "owner_dashboard": "Keep it clean. List properties with status (Active/Pending). Show upcoming bookings in a simple list."
  }
}